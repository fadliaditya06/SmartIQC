@using Smart_IQC.Function
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    string sesa_id = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<style>
    .hero {
        min-height: 70px;
        position: relative;
        display: flex;
        align-items: center;
        color: #fff;
        margin-bottom: 0 !important;
        z-index: 1;
    }

    .hero .position-absolute {
        width: 100%;
    }

    .hero .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.65);
    }

    .hero .hero-body {
        position: relative;
        z-index: 2;
        width: 100%;
    }

    .hero .hero-title {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: 0.2px;
    }

    .inner {
        height: 70px;
        position: relative;
    }

    .main-content-row {
        margin-top: 0 !important;
        padding-top: 0 !important;
    }

    .hero {
        margin-bottom: 0 !important;
    }

    
    .dashboard-card {
        background: #ffffff;
        border-radius: 15px !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1) !important;
        border: none !important;
        margin-bottom: 30px;
        position: relative;
        z-index: 10;
    }

    .dashboard-card:hover {
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    }

    .dashboard-card .card-body {
        padding: 24px;
    }

    .mt-n4 {
        margin-top: -45px !important;
    }

    .dashboard-card .card-body {
        padding: 35px !important;
    }

    .px-md-5 {
        padding-left: 0.5rem !important;
        padding-right: 0.5rem !important;
    }

    .container-fluid {
        max-width: 98%;
        margin: 0 auto;
    }

    .dashboard-card .card-body {
        padding: 30px !important;
    }

    @@media (max-width: 768px) {
        .px-md-5 {
            padding-left: 0.75rem !important;
            padding-right: 0.75rem !important;
        }
    }

    
    :root {
        --first-color: #E3F8FF;
        --second-color: #DCFAFB;
        --third-color: #FFE8DF;
        --accent-color: #FF5151;
        --dark-color: #161616;
    }

    
    *, ::after, ::before {
        box-sizing: border-box;
    }

    body {
        background-color: #fff;
        color: var(--dark-color);
    }


    a {
        text-decoration: none;
    }

    
    .card {
        position: relative;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .container {
        display: block;
        position: relative;
        padding-left: 35px;
        margin-bottom: 12px;
        cursor: pointer;
        font-size: 12px;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
    }

    .select2-container {
        width: 100% !important; 
    }

    .select2-container--default .select2-selection--single {
        height: 40px !important; 
        display: flex !important;
        align-items: center !important;
        justify-content: left !important;
        border: 1px solid #ced4da; 
        border-radius: 0.25rem; 
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 38px !important; 
        padding-left: 10px; 
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 38px; 
        right: 10px; 
    }
</style>

<section id="hero" class="hero bg-dark position-relative" style="background: url('@Url.Content("~/images/background/background-iqc.jpg")') center center / cover no-repeat fixed;">
    <div class="inner d-flex justify-content-between align-items-center px-3 py-2 w-100">
        <div class="position-absolute top-50 start-50 translate-middle text-center">
            <h3 class="text-white mb-0">
                <i class="fa fa-user-shield text-success"></i>
                <b>Wriststrap Check</b>
            </h3>
        </div>
    </div>
</section>

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12 mt-2 mb-2">
                <div class="dashboard-card card-success">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-lg-2 col-md-2 col-sm-6">
                                <div class="form-group">
                                    <label style="font-size:10pt;font-weight:bold;">Week</label>
                                    <input type="week" id="week_filter" style="width:100%;" class="form-control form-control-sm text-center" placeholder="Select Week" />
                                </div>
                            </div>
                            <div class="col-lg-1 col-md-1 col-sm-6">
                                <label style="font-size:10pt;"></label>
                                <div>
                                    <button id="btn_reset" name="btn_reset" class="btn btn-sm btn-warning btn-block mt-2" onclick="window.location.reload()"><i class="fa fa-history mr-1"></i> </button>
                                </div>
                            </div>
                        </div>

                        <!-- Added section -->
                        <div class="row mt-2">
                            <div class="col-8 offset-2 text-center">
                                <div class="d-flex justify-content-center">
                                    <button class="btn btn-warning btn-sm mr-2" style="font-weight: bold; width:100%; pointer-events: none; font-size:10pt">SHIFT 1 : 06:00 AM - 02:59 PM</button>
                                    <button class="btn btn-success btn-sm mr-2" style="font-weight: bold;width:100%; pointer-events: none; font-size:10pt">SHIFT 2 : 03:00 PM - 10:59 PM</button>
                                    <button class="btn btn-sm" style="font-weight: bold; width: 100%; pointer-events: none; background-color: #8FD14F; border-color: #8FD14F; font-size:10pt">SHIFT 3 : 11:00 PM - 05:59 AM</button>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-8 offset-2 text-center">
                                <div class="d-flex justify-content-center">
                                    <button class="btn btn-danger btn-sm mr-2" style="font-weight: bold; width:100%; pointer-events: none; font-size:9pt">NOK</button>
                                    <button class="btn btn-warning btn-sm mr-2" style="font-weight: bold; width:100%; pointer-events: none; font-size:9pt">NOT CHECK</button>
                                    <button class="btn btn-secondary btn-sm mr-2" style="font-weight: bold; width:100%; pointer-events: none; font-size:9pt">NOT RUNNING</button>
                                    <button class="btn btn-success btn-sm mr-2" style="font-weight: bold;width:100%; pointer-events: none; font-size:9pt">OK</button>
                                    <button class="btn btn-sm" style="font-weight: bold; width: 100%; pointer-events: none; background-color: #8FD14F; border-color: #8FD14F; font-size:9pt">OK WITH REMARK</button>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-2">
                            <div class="col-12">
                                <div class="table-responsive" id="TableWristrap"></div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Wriststrap Ok-->
<div class="modal fade" id="modal_layer" tabindex="-1" aria-labelledby="filelabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="content_name"><i class="fas fa-list mr-2"></i>Wriststrap Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row mt-3">
                    <div class="col-12" id="table_details">
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- Modal Wriststrap NG -->
<div class="modal fade" id="modal_ng" tabindex="-1" aria-labelledby="filelabel">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="content_name"><i class="fas fa-list mr-2"></i>Wriststrap Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row mt-3">
                    <div class="col-12" id="table_ng">
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!--Modal Edit jika mau memberikan status Ok-->
<div class="modal fade" id="editinspectorModal" tabindex="-1" aria-labelledby="editinspectorModalLabel">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editinspectorModalLabel"><i class="fa fa-info-circle mr-2"></i> Wriststrap Check</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Inspector Name</label>
                    <input type="text" class="form-control" id="edit_inspector" readonly>
                </div>
                <div class="mb-3">
                    <div class="form-group">
                        <label>Location<span style="color: red">*</span></label>
                        <select class="form-select form-control" id="edit_select_location"></select>
                    </div>
                </div>
                <div class="mb-3">
                    <label>Remark<span style="color: red">*</span></label>
                    <textarea class="form-control" id="edit_remark" placeholder="Enter your remark here"></textarea>
                </div>
                <input type="hidden" id="edit_shift">
                <input type="hidden" id="edit_date">
                <input type="hidden" id="edit_id_daily"> 
                <div class="row w-100 mt-3 justify-content-center">
                    <div class="col-md-4 text-center">
                        <button class="btn btn-success btn-block" id="edit_SC" disabled>
                            <i class="fas fa-check"></i> OK
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal HTML Structure -->
<div class="modal fade mt-5" id="inspectorModal" tabindex="-1" aria-labelledby="inspectorModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="inspectorModalLabel"><i class="fa fa-info-circle mr-2"></i> Wriststrap Check</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="hide_modal()">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">

                <div class="mb-3">
                    <label class="form-label">Wriststrap</label>
                    <input type="text" class="form-control" id="location" readonly>
                    <input type="hidden" class="form-control" id="id_wristrap" readonly>
                </div>
                <div class="mb-3">
                    <label class="form-label">SESA ID<span style="color: red">*</span></label>
                    <input type="text" class="form-control" id="sesaId" readonly>
                </div>
                <input type="hidden" id="shiftValue">
                <input type="hidden" id="dateValue">

                <div class="row w-100 mt-3 justify-content-center">
                    <div class="col-md-4 text-center">
                        <button class="btn btn-success btn-block" id="create_SC">
                            <i class="fas fa-check"></i> OK
                        </button>
                    </div>
                    <div class="col-md-4 text-center">
                        <button class="btn btn-danger btn-block" id="create_NG">
                            <i class="fas fa-times"></i> NG
                        </button>
                    </div>
                </div>
                <div class="mb-3" id="remark-section" style="display: none;">
                    <label>Remark<span style="color: red">*</span></label>
                    <textarea class="form-control" id="remark" placeholder="Enter your remark here"></textarea>
                </div>
                <div class="row w-100 mt-3 justify-content-center">
                    <div class="col-md-4 text-center">
                        <button class="btn btn-primary btn-block" id="submit_button" style="display: none;"><i class="fas fa-save"></i> Submit</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>

        $(document).ready(function () {
            setTimeout(function () {
                applyfilter();
            }, 1000);

            $('#week_filter').on('change', function() {
                applyfilter();
            });

            $.ajax({
                url: "@Url.Action("GetWeekData", "Wristrap")",
                type: "POST",
                success: function (data) {
                    console.log(data)
                    $('#week_filter').val(data[0].current_Week);
                }
            });

        });

        function applyfilter() {
            var week_filter = $('#week_filter').val();
            console.log(week_filter)
            $.ajax({
                type: "GET",
                url: "@Url.Action("GetWristrap", "Wristrap")",
                data: {
                    week_filter: week_filter
                },
                success: function (data) {
                    $("#TableWristrap").html(data);
                    initializeDataTable();
                },
                error: function (xhr, status, error) {
                    console.error('Error fetching filtered data:', error);
                }
            });
        }

        // Fungsi untuk mendapatkan detail data wriststrap yang ok
        function opendetailsok(wristrap, shift, date) {
            $.ajax({
                type: "POST",
                url: "@Url.Action("GetDataWristrapOK", "Wristrap")",
                data: {
                    inspector: wristrap, 
                    shift: shift,
                    check_date: date
                }
            }).done(function (data) {
                $("#modal_layer").modal("show");
                $("#table_details").html(data);
            }).fail(function (xhr) {
                console.error("Error modal:", xhr.responseText);
                Swal.fire('Error', 'Gagal memuat detail data', 'error');
            });
        }

        // Fungsi untuk mendapatkan detail data wriststrap yang ng
        function openng(location, shift, check_date) {
            $.ajax({
                type: "POST",
                url: "@Url.Action("GetDataWristrapNG", "Wristrap")",
                data: {
                    location: location,
                    shift: shift,
                    check_date: check_date
                }
            }).done(function (data) {
                $("#modal_ng").modal("show");
                $("#table_ng").html(data);
            });
        }

        // Fungsi untuk tombol update ketika mau memberikan status ok
        function btn_updates(name, location, remark, id_daily) {
            console.log(name, location, remark, id_daily);

            $('#edit_inspector').val(name).prop('disabled', true);
            $('#edit_select_location').empty().append(new Option(location, location, true, true)).trigger('change').prop('disabled', true);
            $('#edit_remark').val(remark).prop('disabled', true);
            $('#edit_id_daily').val(id_daily); 

            $("#editinspectorModal").modal('show');
            $('#edit_SC').prop('disabled', false);
        }

        $('#editinspectorModal').on('show.bs.modal', function () {
            $('#modal_ng').modal('hide');
        });

        function initializeDataTable() {
            var table = $("#tbl_wristrap");
            if (table.length > 0) {
                table.DataTable({
                    "paging": true,
                    "lengthMenu": [[5, 10, 25, 50, -1], [5, 10, 25, 50, "All"]],
                    "pageLength": 10,
                    "autoWidth": true,
                    "destroy": true,
                    "ordering": false
                });
            } else {
                console.log("Table element not found");
            }
        }

        // Fungsi untuk menyimpan data yg NG menjadi Ok with Remark
        $('#edit_SC').on('click', function () {
            var name = $('#edit_inspector').val();
            var location = $('#edit_select_location').val();
            var remark = $('#edit_remark').val();
            var id_daily = $('#edit_id_daily').val();

            if (name == '' || location == '' || remark == '' || id_daily == '') {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Please fill in all fields',
                });
            } else {
                Swal.fire({
                    title: 'Wristrap Check?',
                    text: "Are you sure to Save this Data?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#28a745',
                    cancelButtonColor: '#dc3545',
                    confirmButtonText: 'Yes!',
                    cancelButtonText: 'No!',
                    showLoaderOnConfirm: true,
                    preConfirm: function () {
                        return $.ajax({
                            type: "POST",
                            url: "@Url.Action("UpdateWristrapCheck")",
                            data: {
                                name: name,
                                location: location,
                                remark: remark,
                                result_final: 'OK',
                                id_daily: id_daily
                            },
                            dataType: "json"
                        }).then(function (data) {
                            if (data.success) {
                                Swal.fire(
                                    'Good job!',
                                    'Success to Add New Data',
                                    'success'
                                );
                                setTimeout(function () {
                                    window.location.reload();
                                }, 2000);
                            } else {
                                Swal.fire(
                                    'Error!',
                                    'Error Add New Data',
                                    'error'
                                );
                            }
                        }).catch(function (error) {
                            Swal.fire(
                                'Error!',
                                'Error Add New Data',
                                'error'
                            );
                            console.error('Error:', error);
                        });
                    }
                });
            }
        });
    </script>
}