<!-- Add Departement Modal -->
<div id="add_departement_modal" class="modal fade" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-building mr-2"></i> Add Department</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-4">
                <div class="form-group">
                    <label>Department ID <span style="color: red">*</span></label>
                    <input type="text" id="new_id_dept" class="form-control form-control-sm" placeholder="Example: FIN, HR, SC" autocomplete="off" required>
                </div>
                <div class="form-group">
                    <label>Department Name <span style="color: red">*</span></label>
                    <input type="text" id="new_departement_name" class="form-control form-control-sm" placeholder="Departement Name" autocomplete="off" required>
                </div>

                <div class="text-center mt-3">
                    <button type="button" class="btn btn-success" id="save_departement" style="width: 150px;">
                        <i class="fas fa-paper-plane mr-1"></i> Save
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $(document).on('click', '[data-toggle="dropdown"]', function (e) {
                e.preventDefault();
                $(this).dropdown('toggle');
            });
            GetUserData()

        });

        $(document).ready(function () {
            $('#access').select2({
                allowClear: true,
                placeholder: "Select an Access Option",
                width: '100%',
                theme: 'classic'
            });

            $('#e_access').select2({
                allowClear: true,
                placeholder: "Select an Access Option",
                width: '100%',
                theme: 'classic'
            });

            $('#add_departement_modal').on('show.bs.modal', function () {
                if ($('#modal_add').is(':visible')) {
                    $(this).data('parent-modal', '#modal_add');
                    $('#modal_add').modal('hide');
                }
                else if ($('#modal_edit').is(':visible')) {
                    $(this).data('parent-modal', '#modal_edit');
                    $('#modal_edit').modal('hide');
                }
            });
        });

        // Fungsi untuk pencarian department di dalam modal add user
        $('#select_departement').select2({
            placeholder: 'Select Departement Name',
            width: '100%', 
            ajax: {
                url: "@Url.Action("GetDeptName", "Admin")", 
                data: function (params) {
                    return {
                        deptname: params.term 
                    };
                },
                processResults: function (data) {
                    return {
                        results: data.items 
                    };
                },
            }
        });

        // Fungsi untuk menyimpan department jika menambahkan department baru
        $("#save_departement").click(function () {
            var idDept = $('#new_id_dept').val();
            var deptName = $('#new_departement_name').val();

            if (idDept === '' || deptName === '') {
                Swal.fire({ icon: 'error', title: 'Error', text: 'All fields are required!' });
                return;
            }

            $.ajax({
                type: "POST",
                url: "@Url.Action("AddDepartment", "Admin")",
                data: { id_dept: idDept, dept_name: deptName },
                success: function (response) {
                    if (response.success) {
                        Swal.fire('Saved!', 'Department added successfully.', 'success').then(() => {
                            $('#new_id_dept').val('');
                            $('#new_departement_name').val('');

                            $('#add_departement_modal').modal('hide');

                            var parentModal = $('#add_departement_modal').data('parent-modal');
                            if (parentModal) {
                                $(parentModal).modal('show');
                            }
                        });
                    } else {
                        Swal.fire('Error', response.message, 'error');
                    }
                }
            });
        });

        function addData() {
            $('#modal_add').modal('show');

        }

        // Fungsi untuk field select department di modal edit
        $('#e_select_departement').select2({
            placeholder: 'Select Departement Name',
            width: '100%',
            dropdownParent: $('#modal_edit'), 
            ajax: {
                url: "@Url.Action("GetDeptName", "Admin")",
                data: function (params) {
                    return { deptname: params.term };
                },
                processResults: function (data) {
                    return { results: data.items };
                },
            }
        });

        // Fungsi untuk mengambil seluruh data user dari database
        function GetUserData() {
            $.ajax({
                type: "GET",
                url: "@Url.Action("GetUserData", "Admin")",
                data: {},

                success: function (data) {
                    $("#FilteredTable").html(data);

                    var table = $("#tbl_user");
                    console.log(table.html()); 

                    if (table.length > 0) {
                        table.DataTable({
                            "paging": true,
                            "lengthMenu": [[5, 10, 25, 50, -1], [5, 10, 25, 50, "All"]],
                            "pageLength": 10,
                        });
                    } else {
                        console.log("Table element not found");
                    }
                }
            });
        }

        // Fungsi untuk memfilter data user berdasarkan department yang dipilih
        function applyfilter() {
            var dept = $("#select_dept :selected").text();
            $.ajax({
                type: "GET",
                url: "@Url.Action("GetUserData", "Admin")",
                data: {
                    dept: dept,
                },
                success: function (data) {
                    $("#FilteredTable").html(data);
                    initializeDataTable(); 
                },
                error: function (xhr, status, error) {
                    console.error('Error fetching filtered data:', error);
                }
            });
        }

        // Fungsi inisialisasi DataTable
        function initializeDataTable() {
            var table = $("#tbl_user");
            if (table.length > 0) {
                table.DataTable({
                    "paging": true,
                    "lengthMenu": [[5, 10, 25, 50, -1], [5, 10, 25, 50, "All"]],
                    "pageLength": 10,
                    "autoWidth": false,
                    "destroy": true,
                    "buttons": [
                        'copy', 'csv', 'excel', 'pdf', 'print'
                    ]
                });
            } else {
                console.log("Table element not found");
            }
        }

        // Fungsi untuk pencarian department
        $(document).ready(function () {
            $('#select_dept').select2({
                placeholder: 'Select Department Name',
                ajax: {
                    url: "@Url.Action("GET_DEPT_USER", "Admin")", 
                    data: function (params) {
                        return {
                            dept: params.term 
                        };
                    },
                    processResults: function (data) {
                        return {
                            results: data.items 
                        };
                    },
                }
            });
        });

        // Fungsi untuk membuka modal tambah data user
        function addData() {
            $('#modal_add').modal('show');
        }

        $("#AddUser").click(function () {
            var accessArray = $('#access').val(); 
            var accessString = accessArray ? accessArray.join(';') : "";

            var sesa_id = $('#sesa_id').val();
            var name = $('#name').val();
            var email = $('#email').val();
            var password = $('#password').val();
            var department = $('#select_departement').val();
            var level = $('#level').val();
            var apps_id = $('#apps_id').val();
            var roles = $('#roles').val();

            if (sesa_id === '' || name === '' || email === '' || password === '' ||
                department === '' || level === '' || accessString === '' || roles === '') {

                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Please fill in all the required fields!'
                });
                return; 
            }

            Swal.fire({
                title: "Are you sure?",
                text: 'Add Master Data?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#dc3545',
                confirmButtonText: 'Yes!',
                cancelButtonText: 'No!',
                showLoaderOnConfirm: true,
                preConfirm: function () {
                    return new Promise(function (resolve, reject) {
                        $.ajax({
                            type: "POST",
                            async: true,
                            url: "@Url.Action("AddUserManagement", "Admin")", // Adjust the action name and controller as necessary
                            data: {
                                sesa_id: sesa_id,
                                name: name,
                                email: email,
                                password: password,
                                department: department,
                                level: level,
                                apps_id: accessString,
                                roles: roles
                            },
                            success: function (data) {
                                if (data.success) {
                                    Swal.fire({
                                        title: 'Added!',
                                        text: 'Your Master Data has been added.',
                                        icon: 'success'
                                    });
                                    setTimeout(function () {
                                        location.reload();
                                    }, 1000);
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Error',
                                        text: data.message || 'An error occurred.'
                                    });
                                }
                            },
                            error: function () {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error',
                                    text: 'An error occurred during the AJAX request.'
                                });
                            }
                        });
                    });
                }
            });
        });

        // Fungsi untuk menampilkan modal edit dan mengisi otomatis semua field berdasarkan data user yang dipilih.
        function btn_edit(id_user, sesa_id, name, password, email, level, access, department, roles) {
            $('#e_sesa_id').val(sesa_id);
            $('#e_name').val(name);
            $('#e_password').val('');
            $('#e_email').val(email);
            $('#e_level').val(level);
            $('#e_roles').val(roles);

            $('#e_select_departement').select2({
                placeholder: 'Select Departement Name',
                width: '100%',
                dropdownParent: $('#modal_edit'),
                ajax: {
                    url: "@Url.Action("GetDeptName", "Admin")",
                    data: function (params) { return { deptname: params.term }; },
                    processResults: function (data) { return { results: data.items }; }
                }
            });

            var $option = $("<option selected></option>").val(department).text(department);
            $('#e_select_departement').empty().append($option).trigger('change');

            if (access) {
                var selectedApps = access.split(';');
                $('#e_access').val(selectedApps).trigger('change');
            } else {
                $('#e_access').val(null).trigger('change');
            }

            $("#modal_edit").modal('show');
        }

        // Fungsi untuk memvalidasi perubahan data pada modal edit dan mengirimkannya ke server untuk diperbarui.
        function verify_save() {
            var accessArray = $('#e_access').val();
            var accessString = accessArray ? accessArray.join(';') : "";
            var sesa_id    = $('#e_sesa_id').val();
            var name       = $('#e_name').val();
            var email      = $('#e_email').val();
            var password   = $('#e_password').val();
            var department = $('#e_select_departement').val(); 
            var level      = $('#e_level').val();
            var roles      = $('#e_roles').val();

            console.log({sesa_id, name, email, department, level, roles});

            if (!sesa_id || !name || !email || !department || !level || !roles || !accessString) {
                Swal.fire({
                    icon: 'error',
                    title: 'Failed',
                    text: 'All marked fields are required!'
                });
                return;
            }

            Swal.fire({
                title: 'Confirm Edit?',
                text: "Save this user data change?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                confirmButtonText: 'Yes, Save!',
                showLoaderOnConfirm: true,
                preConfirm: () => {
                    return $.ajax({
                        type: "POST",
                        url: "@Url.Action("UpdateData", "Admin")",
                        data: {
                            sesa_id: sesa_id,
                            name: name,
                            email: email,
                            password: password,
                            department: department,
                            level: level,
                            apps_id: accessString,
                            roles: roles
                        }
                    }).done(function (data) {
                        if (data == 1) {
                            Swal.fire('Success!', 'Data has been updated.', 'success').then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Failed', 'Data not changed or SESA ID not found.', 'error');
                        }
                    }).fail(function () {
                        Swal.fire('Error', 'An error occurred on the server.', 'error');
                    });
                }
            });
        }

        // Fungsi untuk menghapus data user berdasarkan id user
        function btn_delete(id) {
            if (id == '') {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Please Fill in All the requirement first !'
                })
            }
            else {
                Swal.fire({
                    title: 'Confirm Delete?',
                    text: "Are you sure to Delete Data? ",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#28a745',
                    cancelButtonColor: '#dc3545',
                    confirmButtonText: 'Yes!',
                    cancelButtonText: 'No!',
                    showLoaderOnConfirm: true,
                    preConfirm: function () {
                        return new Promise(function (resolve, reject) {
                            $.ajax({
                                type: "POST",
                                url: "@Url.Action("DeleteData", "Admin")",
                                data: {
                                    id_user: id
                                },
                                dataType: "json",
                                success: function () {
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'Success',
                                        text: 'Deleted Successfully !'
                                    })
                                    setTimeout(function () {
                                        window.location.href = '@Url.Action("UserManagement", "Admin")';
                                    }, 1000); 
                                }
                            });

                        })
                    }

                })

            }
        }
    </script>
}