@using Smart_IQC.Function
@using Microsoft.AspNetCore.Http;
@inject IHttpContextAccessor HttpContextAccessor
@{
    DateTime dt = DateTime.Now;
    var Month = dt.ToString("MMMM");

    if (HttpContextAccessor.HttpContext.Session == null)
    {
        Url.Action("Logout", "Home");
    }
}

<style>
    .container {
        display: block;
        position: relative;
        padding-left: 35px;
        margin-bottom: 12px;
        cursor: pointer;
        font-size: 12px;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
    }

    
    #modal_add, #modal_edit {
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
    }

    #modal_add .modal-header h5, #modal_edit .modal-header h5 {
        font-weight: 600px;
        margin: 0;
    }

    #modal_add .modal-body, #modal_edit .modal-body {
        padding: 20px;
    }

    #modal_add .form-group, #modal_edit .form-group {
        margin-bottom: 20px;
    }

    #modal_add .form-control, #modal_edit .form-control {
        border: 1px solid #ccc;
        border-radius: 5px;
        font-size: 14px; 
    }

    #modal_add .form-control:focus, #modal_edit .form-control:focus {
        border-color: #3dcd58;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
    }

    #modal_add .form-control:hover, #modal_edit .form-control:hover {
        border-color: #aaa; 
    }

    #modal_add .btn, #modal_edit .btn {
        padding: 10px 20px;
        border: none;
        border-radius: 5px;
        background-color: #3dcd58;
        color: #fff;
        cursor: pointer;
        transition: background-color 0.3s ease; 
    }

    #modal_add .btn:hover, #modal_edit .btn:hover {
        background-color: #2ecc71;
    }

    #modal_add .btn:active, #modal_edit .btn:active {
        background-color: #27ae60;
    }

    #modal_add .form-control select, #modal_edit .form-control select {
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 5px;
        height: 40px;
        background-color: #fff;
        color: #333;
        font-size: 16px;
        vertical-align: middle;
    }

    #modal_add .form-control select:focus, #modal_edit .form-control select:focus {
        border-color: #3dcd58;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
    }

    #modal_add .form-control select option, #modal_edit .form-control select option {
        padding: 10px;
        border-bottom: 1px solid #ccc;
    }

    #modal_add .form-control select option:hover, #modal_edit .form-control select option:hover {
        background-color: #f9f9f9;
    }

    .select2-container .select2-selection--single .select2-selection__placeholder {
        font-size: 14px !important;
        color: #999;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        font-size: 14px !important; 
    }

    .select2-container--classic .select2-selection--multiple .select2-selection__placeholder {
        margin-left: 5px !important;
        color: #6c757d !important; 
    }

    .select2-container--classic .select2-selection--multiple {
        padding-left: 8px !important; 
        border: 1px solid #ccc !important; 
        border-radius: 5px !important;
    }

    .select2-container--classic .select2-search--inline .select2-search__field {
        font-size: 14px !important;
        margin-left: 5px !important;
    }

    .hero {
        min-height: 70px;
        position: relative;
        display: flex;
        align-items: center;
        color: #fff;
        margin-bottom: 0 !important;
        z-index: 1;
    }

    .hero .position-absolute {
        width: 100%;
    }

    .hero .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.65);
    }

    .hero .hero-body {
        position: relative;
        z-index: 2;
        width: 100%;
    }

    .hero .hero-title {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: 0.2px;
    }

    .inner {
        height: 70px;
        position: relative;
    }

    .main-content-row {
        margin-top: 0 !important;
        padding-top: 0 !important;
    }

    .hero {
        margin-bottom: 0 !important;
    }

    
    .dashboard-card {
        background: #ffffff;
        border-radius: 15px !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1) !important;
        border: none !important;
        margin-bottom: 30px;
        position: relative;
        z-index: 10;
    }

    .dashboard-card:hover {
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    }

    .dashboard-card .card-body {
        padding: 24px;
    }

    .mt-n4 {
        margin-top: -45px !important;
    }

    .dashboard-card .card-body {
        padding: 35px !important;
    }

    .px-md-5 {
        padding-left: 0.5rem !important;
        padding-right: 0.5rem !important;
    }

    .container-fluid {
        max-width: 98%;
        margin: 0 auto;
    }

    .dashboard-card .card-body {
        padding: 30px !important;
    }

    @@media (max-width: 768px) {
        .px-md-5 {
            padding-left: 0.75rem !important;
            padding-right: 0.75rem !important;
        }
    }
</style>

<section id="hero" class="hero bg-dark position-relative" style="background: url('@Url.Content("~/images/background/background-iqc.jpg")') center center / cover no-repeat fixed;">
    <div class="inner d-flex justify-content-between align-items-center px-3 py-2 w-100">
        <div class="position-absolute top-50 start-50 translate-middle text-center">
            <h3 class="text-white mb-0">
                <i class="fa fa-users text-success"></i>
                <b>User Management</b>
            </h3>
        </div>
    </div>
</section>

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12 mt-3">
                <div class="dashboard-card">
                    <div class="card-body">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <button class="btn btn-primary btn-sm mr-2" onclick="addData()">
                                    <i class="fa fa-plus"></i> Add User
                                </button>

                                <button id="btn_reset" class="btn btn-sm btn-warning" onclick="window.location.reload()">
                                    <i class="fa fa-history mr-1"></i> Refresh Data
                                </button>
                            </div>

                            <div class="row align-items-end">
                                <div class="col-lg-10 col-md-9">
                                    <div class="form-group mb-0">
                                        <label style="font-size:10pt;font-weight:bold;">Department Filter</label>
                                        <select class="form-control form-control-sm" id="select_dept" style="width:100%;">
                                        </select>
                                    </div>
                                </div>
                                <div class="col-lg-2 col-md-3">
                                    <button onclick="applyfilter()" class="btn btn-success btn-sm btn-block">
                                        <i class="fa fa-search mr-1"></i> Search
                                    </button>
                                </div>
                            </div>

                            <div class="row mt-4">
                                <div class="col-12" id="FilteredTable">
                                    <div id="spinner_loading" class="text-center mt-2">
                                        <i class="fas fa-spinner fa-spin fa-lg" style="font-size:30pt;"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Modal Add User *@
<div id="modal_add" class="modal fade" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-user-plus mr-2"></i> Add User</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-4">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="sesa_id">SESA ID <span style="color: red">*</span></label>
                            <input type="text" id="sesa_id" name="sesa_id" placeholder="SESA ID" class="form-control form-control-sm" autocomplete="off" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Name <span style="color: red">*</span></label>
                            <input id="name" class="form-control form-control-sm" placeholder="Name" style="width: 100%;" autocomplete="off" required>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Email <span style="color: red">*</span></label>
                            <input type="text" id="email" class="form-control form-control-sm" placeholder="Email" autocomplete="off" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Password <span style="color: red">*</span></label>
                            <input type="password" id="password" class="form-control form-control-sm" placeholder="Password" style="width: 100%;" autocomplete="new-password" required>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-5">
                        <div class="form-group">
                            <label>Departement <span style="color: red">*</span></label>
                            <select class="form-control form-control-sm" id="select_departement" placeholder="Departement" required></select>
                        </div>
                    </div>
                    <div class="col-sm-1 d-flex align-items-end" style="margin-left: -10px; margin-bottom: 20.5px; margin-right:10px">
                        <button type="button" class="btn btn-primary btn-sm"
                                data-toggle="modal" data-target="#add_departement_modal"
                                style="width: 30px; height: 30px; padding: 0; display: flex; align-items: center; justify-content: center;">
                            <i class="fa fa-plus" style="font-size: 10px;"></i>
                        </button>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Level <span style="color: red">*</span></label>
                            <select class="form-control form-control-sm" id="level" required>
                                <option value="" selected disabled hidden>Select Level</option>
                                <option value="admin">Admin</option>
                                <option value="inspector">Inspector</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                        <div class="form-group">
                            <label>Access <span style="color: red">*</span></label>
                            <select class="form-control select2-multiple" id="access" multiple="multiple" style="width: 100%;">
                                <option value="APP-IQC">Smart IQC</option>
                                <option value="APP-TH">Temperature Humidity</option>
                                <option value="APP-WRI">Wriststrap</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                        <div class="form-group">
                            <label>Role Confirmation <span style="color: red">*</span></label>
                            <select class="form-control form-control-sm" id="roles" required>
                                <option value="" selected disabled hidden>Select Level</option>
                                <option value="metrology">Metrology</option>
                                <option value="SQE">SQE</option>
                                <option value="-">(none)</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Submit Button -->
            <center>
                <div class="col-6 text-center p-4">
                    <button class="btn btn-success btn-block" id="AddUser">
                        <i class="fas fa-paper-plane mr-1"></i> Submit
                    </button>
                </div>
            </center>
        </div>
    </div>
</div>

