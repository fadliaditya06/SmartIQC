@model List<THCheckModel>
@using Microsoft.AspNetCore.Http;
@using P1F_IQC.Function

@{
    bool showRemarkColumn = Model.Any(m => m.audit_status == "NOK");
}

<style>
    .dropdown-menu {
        padding: 10px;
    }

    .dropdown-item {
        margin-bottom: 10px;
    }

    .dropdown-toggle {
        background-color: #337ab7;
        border-color: #2e6da4;
        color: #fff;
    }

    #tbl_history {
        margin: 0 auto;
    }

    #tbl_history th, #tbl_history td {
        padding: 10px;
    }

    #tbl_history tr:nth-child(even) {
        background-color: #f2f2f2;
    }

    #tbl_history tr:hover {
        background-color: #ddd;
    }

    .btn-circle {
        border-radius: 50%;
        width: 30px;
        height: 30px;
        padding: 6px;
        font-size: 12px;
        margin: 5px;
    }
</style>

<table id="tbl_history" class="table table-sm table-bordered table-striped">
    <thead class="bg-secondary">
        <tr style="font-size: 12pt;">
            <th class="align-middle text-center" style="width: 5%;">Inspection Trip</th>
            <th class="align-middle text-center" style="width: 15%;">Location</th>
            <th class="align-middle text-center" style="width: 15%;">Temperature Value</th>
            <th class="align-middle text-center" style="width: 15%;">Temperature Status</th>
            <th class="align-middle text-center" style="width: 15%;">Humidty Value</th>
            <th class="align-middle text-center" style="width: 15%;">Humidity Status</th>
            <th class="align-middle text-center" style="width: 15%;">Inspection By</th>
            <th class="align-middle text-center" style="width: 20%;">Inspection Date</th>
            <th class="align-middle text-center" style="width: 20%;">Remark</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var mat in Model)
            {
            <tr class="align-middle" style="font-size: 12pt;">
                <td class="text-center align-middle">@mat.insp_trip</td>
                <td class="text-center align-middle">@mat.location</td>
                <td class="text-center align-middle">@mat.temperature_value</td>
                <td class="text-center align-middle @(mat.temperature_status == "OK" ? "bg-success text-light" : mat.temperature_status == "NOK" ? "bg-danger text-light" : "")">@mat.temperature_status</td>
                <td class="text-center align-middle">@mat.humidity_value</td>
                <td class="text-center align-middle @(mat.humidity_status == "OK" ? "bg-success text-light" : mat.humidity_status == "NOK" ? "bg-danger text-light" : "")">@mat.humidity_status</td>
                <td class="text-center align-middle">@mat.user_id</td>
                <td class="text-center align-middle" style="width:20%">@mat.insp_date</td>
                @if (mat.audit_status == "NOK")
                {
                    <td class="text-center align-middle" style="width:20%">@mat.remark</td>
                }
                else
                {
                    <td class="text-center align-middle" style="width:20%">-</td>
                }
            </tr>
        }
    </tbody>
</table>