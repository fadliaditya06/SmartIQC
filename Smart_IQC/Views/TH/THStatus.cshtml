@using Smart_IQC.Function
@using Microsoft.AspNetCore.Http;
@using System.Globalization;
@inject IHttpContextAccessor HttpContextAccessor

@{
    DateTime now = DateTime.Now;

    int weekNum = System.Globalization.CultureInfo.InvariantCulture.Calendar.GetWeekOfYear(
        now,
        System.Globalization.CalendarWeekRule.FirstFourDayWeek,
        DayOfWeek.Monday);

    string currentWeekFilter = $"{now.Year}-W{weekNum:D2}";
}

<style>
    .hero {
        min-height: 70px;
        position: relative;
        display: flex;
        align-items: center;
        color: #fff;
        margin-bottom: 0 !important;
        z-index: 1;
    }

    .hero .position-absolute {
        width: 100%;
    }

    .hero .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.65);
    }

    .hero .hero-body {
        position: relative;
        z-index: 2;
        width: 100%;
    }

    .hero .hero-title {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: 0.2px;
    }

    .inner {
        height: 70px;
        position: relative;
    }

    .main-content-row {
        margin-top: 0 !important;
        padding-top: 0 !important;
    }

    .hero {
        margin-bottom: 0 !important;
    }

    
    .dashboard-card {
        background: #ffffff;
        border-radius: 15px !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1) !important;
        border: none !important;
        margin-bottom: 30px;
        position: relative;
        z-index: 10;
    }

    .dashboard-card:hover {
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    }

    .dashboard-card .card-body {
        padding: 24px;
    }

    .mt-n4 {
        margin-top: -45px !important;
    }

    .dashboard-card .card-body {
        padding: 35px !important;
    }

    .px-md-5 {
        padding-left: 0.5rem !important;
        padding-right: 0.5rem !important;
    }

    .container-fluid {
        max-width: 98%;
        margin: 0 auto;
    }

    .dashboard-card .card-body {
        padding: 30px !important;
    }

    @@media (max-width: 768px) {
        .px-md-5 {
            padding-left: 0.75rem !important;
            padding-right: 0.75rem !important;
        }
    }

    .btn-primary {
        background-color: #F96E2A !important;
    }

    .container {
        display: block;
        position: relative;
        padding-left: 35px;
        margin-bottom: 12px;
        cursor: pointer;
        font-size: 12px;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
    }

    .container input {
        position: absolute;
        opacity: 0;
        cursor: pointer;
    }
</style>

<section id="hero" class="hero bg-dark position-relative" style="background: url('@Url.Content("~/images/background/background-iqc.jpg")') center center / cover no-repeat fixed;">
    <div class="inner d-flex justify-content-between align-items-center px-3 py-2 w-100">
        <div class="position-absolute top-50 start-50 translate-middle text-center">
            <h3 class="text-white mb-0">
                <i class="fa fa-clipboard-list text-success"></i>
                <b>Daily Temperature Humidity Check Status</b>
            </h3>
        </div>
    </div>
</section>

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12 mt-2 mb-2">
                <div class="dashboard-card card-success">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-lg-2 col-md-2 col-sm-6">
                                <div class="form-group">
                                    <label style="font-size:10pt;font-weight:bold;">Week</label>
                                    <input type="week" id="week_filter" style="width:100%;" class="form-control form-control-sm text-center" placeholder="Select Week" value="@currentWeekFilter" />
                                </div>
                            </div>
                            <div class="col-lg-1 col-md-1 col-sm-6">
                                <label style="font-size:10pt;"></label>
                                <div>
                                    <button id="btn_reset" name="btn_reset" class="btn btn-sm btn-warning btn-block mt-2" onclick="window.location.reload()"><i class="fa fa-history mr-1"></i> </button>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-2 mb-3">
                            <div class="col-8 offset-2 text-center">
                                <div class="d-flex justify-content-center">
                                    <button class="btn btn-primary btn-sm mr-2" style="font-weight: bold; width:30%; pointer-events: none; font-size:10pt">TRIP 1 : 12:00 AM - 02:59 PM</button>
                                    <button class="btn btn-warning btn-sm mr-2" style="font-weight: bold; width:30%; pointer-events: none; font-size:10pt">TRIP 2 : 03:00 PM - 11:59 PM</button>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-4 mb-3">
                                <div class="col-8 offset-2 text-center">
                                    <div class="d-flex justify-content-center">
                                        <button class="btn btn-danger btn-sm mr-2" style="font-weight: bold; width:30%; pointer-events: none; font-size:9pt">NOK</button>
                                        <button class="btn btn-primary btn-sm mr-2" style="font-weight: bold; width:30%; pointer-events: none; font-size:9pt">NOK WITH REMARK</button>
                                        <button class="btn btn-warning btn-sm mr-2" style="font-weight: bold; width:30%; pointer-events: none; font-size:9pt">NOT CHECK</button>
                                        <button class="btn btn-secondary btn-sm mr-2" style="font-weight: bold; width:30%; pointer-events: none; font-size:9pt">NOT RUNNING</button>
                                        <button class="btn btn-success btn-sm" style="font-weight: bold;width:30%; pointer-events: none; font-size:9pt">OK</button>
                                    </div>
                                </div>
                        </div>

                        <div class="row mt-2">
                            <div class="col-12">
                                <div class="table-responsive" id="FilteredTable"></div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal_layer" tabindex="-1" aria-labelledby="filelabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="content_name"><i class="fas fa-list mr-2"></i>Temperature Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row mt-3">
                    <div class="col-12" id="table_details">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Fungsi untuk menampilkan th daily status dalam periode minggu tertentu
        function applyfilter() {
            var week_filter = $('#week_filter').val();
            console.log("Filtering for Week:", week_filter)

            $.ajax({
                type: "GET",
                url: "@Url.Action("GetDashTHCheck", "TH")",
                data: {
                    week_filter: week_filter
                },
                beforeSend: function() {
                   $('#FilteredTable').html('<div class="d-flex justify-content-center mt-5"><i class="fa fa-spinner fa-spin fa-3x fa-fw"></i><span class="sr-only">Loading...</span></div>');
                },
                success: function (data) {
                    $("#FilteredTable").html(data);
                    initializeDataTable();
                },
                error: function (xhr, status, error) {
                    console.error('Error fetching filtered data:', error);
                    $("#FilteredTable").html('<p class="text-danger">Failed to load data. Please check the server.</p>');
                }
            });
        }


        $(document).ready(function () {
            var weekInput = $('#week_filter');

            if (!weekInput.val()) {
                var now = new Date();
                var year = now.getFullYear();

                now.setDate(now.getDate() + 4 - (now.getDay() || 7));
                var yearStart = new Date(now.getFullYear(), 0, 1);
                var weekNo = Math.ceil((((now - yearStart) / 86400000) + 1) / 7);

                var formattedWeek = now.getFullYear() + "-W" + (weekNo < 10 ? "0" + weekNo : weekNo);
                weekInput.val(formattedWeek);
            }

            weekInput.on('change', function() {
                applyfilter(); 
            });

            applyfilter();
        });

        // Fungsi inisialisasi DataTable
        function initializeDataTable() {
            var table = $("#tbl_history");
            if (table.length > 0 && !$.fn.DataTable.isDataTable('#tbl_history')) {
                 table.DataTable({
                    "paging": true,
                    "lengthMenu": [[5, 10, 25, 50, -1], [5, 10, 25, 50, "All"]],
                    "pageLength": 10,
                    "autoWidth": false,
                    "destroy": true,
                    "ordering": false
                });
            } else if ($.fn.DataTable.isDataTable('#tbl_history')) {
                 table.DataTable().destroy();
                 table.DataTable({
                    "paging": true,
                    "lengthMenu": [[5, 10, 25, 50, -1], [5, 10, 25, 50, "All"]],
                    "pageLength": 10,
                    "autoWidth": true,
                    "destroy": true,
                    "ordering": false
                });
            }
        }

        // Fungsi untuk menampilkan detail data TH dalam modal
        function opendetails(location, insp_date) {
            $.ajax({
                type: "POST",
                url: "@Url.Action("GetDataTHCheck", "TH")",
                data: {
                    location: location,
                    insp_date: insp_date
                }
            }).done(function (data) {
                $("#modal_layer").modal("show");
                $("#table_details").html(data);
            });
        }

        // Fungsi untuk menavigasi ke halaman TH Check
        function opencell(location) {
            localStorage.setItem('location', location);
            var url = "@Url.Action("THCheck", "TH")" + "?location=" + encodeURIComponent(location);

            console.log("Redirecting to: " + url);
            window.location.href = url;
        }

        function btn_edit() {
            window.location.href = "@Url.Action("THCheck", "TH")";
        }
    </script>
}