@{
    ViewData["Title"] = "Quality Policy";
    var dynamicPdfPath = Url.Content("~/assets/Quality Policy.pdf");
}

<style>
    /* --- Base Layout --- */
    body {
        background-color: #f4f7f6;
        overflow-x: hidden;
    }

    .hero {
        height: 100px; 
        display: flex;
        align-items: center;
        background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('@Url.Content("~/images/background/background-iqc.jpg")') center no-repeat fixed;
        border-bottom: 5px solid #28a745; 
    }

    .hero-title {
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .policy-container {
        margin-top: 25px;
        position: relative;
        z-index: 10;
        padding-bottom: 40px;
    }

    .pdf-main-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #dee2e6;
        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    /* --- Header Bar --- */
    .pdf-header-bar {
        background: #ffffff;
        padding: 12px 20px;
        border-bottom: 2px solid #f1f1f1;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .doc-info h5 {
        font-size: 1.1rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 0;
    }

    .doc-info small {
        color: #6c757d;
        display: flex;
        align-items: center;
    }

    /* --- Viewer Styling --- */
    .viewer-wrapper {
        height: 78vh; 
        background: #525659;
        position: relative;
    }

    #mainDocumentViewer {
        width: 100%;
        height: 100%;
        border: none;
    }

    /* --- Buttons --- */
    .btn-fullscreen {
        border-radius: 25px;
        padding: 6px 18px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.2s ease;
    }

    /* --- Modal Customization --- */
    #documentPreviewModal .modal-content {
        border-radius: 15px;
        border: none;
        height: 92vh;
    }

    #documentPreviewModal .modal-body {
        background: #525659;
    }

    .close-modal {
        color: white;
        opacity: 0.8;
    }

    .close-modal:hover {
        color: white;
        opacity: 1;
    }
</style>

<section class="hero shadow-sm">
    <div class="container-fluid">
        <div class="text-center">
            <h3 class="text-white mb-0 hero-title">
                <i class="fa fa-award text-success mr-2"></i> Quality Policy
            </h3>
        </div>
    </div>
</section>

<div class="container-fluid policy-container">
    <div class="row justify-content-center">
        <div class="col-lg-11 col-xl-10">
            <div class="pdf-main-card">
                <div class="pdf-header-bar">
                    <div class="doc-info">
                        <h5>Document Viewer</h5>
                        <small>
                            <i class="fa fa-file-pdf text-danger mr-2"></i>
                            Quality Policy.pdf
                        </small>
                    </div>
                    <button class="btn btn-outline-success btn-fullscreen shadow-sm" onclick="openPdfModal()">
                        <i class="fa fa-expand mr-1"></i> Fullscreen View
                    </button>
                </div>

                <div class="viewer-wrapper">
                    <iframe id="mainDocumentViewer"
                            src="@dynamicPdfPath#view=FitH"
                            allow="autoplay">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="documentPreviewModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered" role="document" style="max-width: 95%;">
        <div class="modal-content shadow-lg">
            <div class="modal-header">
                <h5 class="modal-title m-0" style="font-size: 1rem;">
                    <i class="fa fa-file-pdf text-danger mr-2"></i> Quality Policy - Fullscreen Preview
                </h5>
                <button type="button" class="close close-modal" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-0">
                <iframe id="modalDocumentViewer" src="" style="width:100%; height:100%; border:none;"></iframe>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            window.openPdfModal = function () {
                const pdfPath = "@dynamicPdfPath#view=FitH";
                const $modalViewer = $('#modalDocumentViewer');

                if ($modalViewer.attr('src') === "") {
                    $modalViewer.attr('src', pdfPath);
                }

                $('#documentPreviewModal').modal('show');
            };

            $('#documentPreviewModal').on('hidden.bs.modal', function () {
            });
        });
    </script>
}