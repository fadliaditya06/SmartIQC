@model List<Smart_IQC.Models.DefectLibraryModel>
@{
    ViewData["Title"] = "Defect Library";
}

<style>
    .border-left {
        border-left: 1px solid #dee2e6 !important;
    }

    .hero {
        min-height: 70px;
        position: relative;
        display: flex;
        align-items: center;
        color: #fff;
        margin-bottom: 0 !important;
        z-index: 1;
    }

    .hero .position-absolute {
        width: 100%;
    }

    .hero .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.65);
    }

    .hero .hero-body {
        position: relative;
        z-index: 2;
        width: 100%;
    }

    .hero .hero-title {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: 0.2px;
    }

    .inner {
        height: 70px;
        position: relative;
    }

    .main-content-row {
        margin-top: 0 !important;
        padding-top: 0 !important;
    }

    .hero {
        margin-bottom: 0 !important;
    }

    .dashboard-card {
        background: #ffffff;
        border-radius: 15px !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1) !important;
        border: none !important;
        margin-bottom: 30px;
        position: relative;
        z-index: 10;
    }

    .dashboard-card:hover {
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    }

    .dashboard-card .card-body {
        padding: 24px;
    }

    .mt-n4 {
        margin-top: -45px !important;
    }

    .dashboard-card .card-body {
        padding: 35px !important;
    }

    .px-md-5 {
        padding-left: 0.5rem !important;
        padding-right: 0.5rem !important;
    }

    .container-fluid {
        max-width: 98%;
        margin: 0 auto;
    }

    .dashboard-card .card-body {
        padding: 30px !important;
    }

    @@media (max-width: 768px) {
        .px-md-5 {
            padding-left: 0.75rem !important;
            padding-right: 0.75rem !important;
        }
    }
</style>

<section id="hero" class="hero bg-dark position-relative" style="background: url('@Url.Content("~/images/background/background-iqc.jpg")') center center / cover no-repeat fixed;">
    <div class="inner d-flex justify-content-between align-items-center px-3 py-2 w-100">
        <div class="position-absolute top-50 start-50 translate-middle text-center">
            <h3 class="text-white mb-0">
                <i class="fa fa-book text-success"></i>
                <b>Defect Library</b>
            </h3>
        </div>
    </div>
</section>

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12 mt-3">
                <div class="dashboard-card shadow-sm">
                    <div class="card-body" id="tableContainer">
                        <partial name="_TableDefectLibrary" model="Model" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="imageDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow-lg" style="border-radius: 15px;">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">
                    <i class="fas fa-search-plus mr-2"></i> Detail Picture
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body text-center bg-light">
                <img id="modalImage" src="" class="img-fluid rounded shadow" alt="Full Detail" style="max-height: 80vh; border: 3px solid #fff;" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#defectTable').DataTable({
                "destroy": true,
                "paging": true,
                "lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
                "pageLength": 10,
                "responsive": true,
                "autoWidth": false,
                "order": [[0, 'asc']], 
                "drawCallback": function() {
                    $('.dataTables_paginate > .pagination').addClass('pagination-sm');
                }
            });
        });

        // Fungsi untuk menampilkan modal gambar
        function showImageModal(src, title) {
            $('#modalImage').attr('src', src);
            $('#modalTitle').html('<i class="fas fa-search-plus mr-2"></i> Detail ' + title);
            $('#imageDetailModal').modal('show');
        }
    </script>
}