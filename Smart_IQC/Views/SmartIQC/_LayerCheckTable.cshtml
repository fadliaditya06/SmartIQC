@model ViewModel

<style>
    .professional-table {
        table-layout: fixed;
        width: 100% !important;
        font-size: 12px;
        border-collapse: separate;
        border-spacing: 0;
        clip-path: inset(0 round 8px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .professional-table thead th {
        background: var(--primary-blue);
        color: white;
        font-weight: 600;
        text-align: center;
        vertical-align: middle;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .professional-table tbody td {
        border: 1px solid #f0f0f0;
        vertical-align: middle;
    }

    .professional-table tbody tr:hover {
        background-color: var(--background-gray);
    }

    .professional-table th,
    .professional-table td {
        box-sizing: border-box;
        word-wrap: break-word;
        word-break: break-word;
        white-space: normal !important;
        overflow-wrap: break-word;
    }

    .professional-table thead tr:first-child th {
        border-bottom: 2px solid white !important;
        padding-bottom: 10px !important;
    }

    .professional-table thead tr:nth-child(2) th {
        border-top: none !important;
        padding-top: 12px !important;
        padding-bottom: 12px !important;
    }

    .text-wrap-limit {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .filter_table, .column-filter {
        margin-top: 2px;
        border-radius: 6px !important;
    }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2; 
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.2;
    }
</style>

<table id="table_layer_check" class="table professional-table table-sm" style="table-layout:fixed">
    <thead>
        <tr class="bg-info">
            <th class="align-middle text-center" width="5%"><i class="fas fa-list-ol"></i> No</th>
            <th class="align-middle text-center" width="10%"><i class="fas fa-tag"></i> Unique Reff</th>
            <th class="align-middle text-center" width="13%"><i class="fas fa-map-marker-alt"></i> Location</th>
            <th class="align-middle text-center" width="25%"><i class="fas fa-exclamation-triangle"></i> Defect Description</th>
            <th class="align-middle text-center" width="30%"><i class="fas fa-clipboard-check"></i> Inspection Step</th>
            <th class="align-middle text-center" width="15%"><i class="fas fa-user-check"></i> Check</th>
            <th class="align-middle text-center" width="10%"><i class="fas fa-poll-h"></i> Status</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.CheckLayerDetails != null && Model.CheckLayerDetails.Any())
        {
            int i = 0; 
            foreach (var item in Model.CheckLayerDetails)
            {
                i++; 
                    <tr data-unique-reff="@item.Unique_Reff">
                        <td class="align-middle text-center" style="font-size:9pt;">@i</td>
                        <td class="align-middle text-center" style="font-size:9pt;"><b>@item.Unique_Reff</b></td>

                    <td class="align-middle text-left" style="font-size:9pt;">
                        <div class="d-flex align-items-start">
                            <a href="#" class="mr-2 pt-1">
                                <span class="fa fa-info-circle text-warning" data-toggle="tooltip" title="@item.Location"></span>
                            </a>
                            <span>@item.Location</span>
                        </div>
                    </td>

                    <td class="align-middle text-left" style="font-size:9pt;">
                        <div class="d-flex align-items-start">
                            <a href="#" class="mr-2 pt-1">
                                <span class="fa fa-info-circle text-warning" data-toggle="tooltip" title="@item.Defect_Description"></span>
                            </a>
                            <span>@item.Defect_Description</span>
                        </div>
                    </td>

                    <td class="align-middle text-left" style="font-size:9pt;">
                        <a href="#"><span class="fa fa-info-circle text-warning" data-toggle="tooltip" data-original-title="@item.Inspection_Step"></span></a>
                        @item.Inspection_Step
                    </td>

                    <td class="align-middle text-center">
                        <button type="button" class="btn btn-sm btn-success btn-status mx-1" data-status="OK" style="width: 27pt">
                            <i class="fas fa-check"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-danger btn-status mx-1" data-status="NOK" style="width: 27pt">
                            <i class="fas fa-times"></i>
                        </button>
                    </td>

                    <td class="align-middle text-center">
                        <span style="font-size:1rem;" class="badge badge-pill badge-info"><i class="fas fa-question"></i></span>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr class="text-center">
                <td colspan="7" class="align-middle">No Data to Display</td>
            </tr>
        }
    </tbody>
</table>