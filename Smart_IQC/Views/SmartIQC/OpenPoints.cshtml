@section Scripts {
    <script>
        $("button[name=btn_af_upload1]").click(function () {
            $("#image_af_upload1").click();
        });

        $("#pic_af1").click(function () {
            $("#image_af_upload1").click();
        });

        // Fungsi untuk membaca file gambar dari input dan menampilkannya sebagai preview (termasuk validasi ukuran img)
        function readimgaf1(input) {
            if (input.files && input.files[0]) {
                var reader1 = new FileReader();
                if (input.files[0].size > 10000000) {
                    Swal.fire({
                        title: 'Error...',
                        type: 'error',
                        text: 'Image size too large! Maximum size is 10000000 bytes',
                        footer: 'Your image size is ' + input.files[0].size + ' bytes',
                    });
                    return document.getElementById("pic_af1").value = "";
                }
                reader1.onload = function (e) {
                    $('#pic_af1').attr('src', e.target.result);
                };
                reader1.readAsDataURL(input.files[0]);
                return;
            }
            document.getElementById("pic_af1").value = "";
        }

        // Fungsi untuk melihat detail gambar 
        function zoomImage(imagePath, title) {
            var noImagePath = '@Url.Content("~/images/not_available.png")';
            $("#modal_image_title").text(title || "Defect Picture");

            $("#show_img_single").attr("src", "");
            $("#show_image").modal("show");
            $("#show_img_single").attr("src", imagePath);
            $("#show_img_single").attr("onerror", "this.onerror=null; this.src='" + noImagePath + "';");

            $("#show_image .close").off('click').on('click', function() {
                information_modal_close();
            });
        }

        // Fungsi untuk menutup modal detail gambar
        function information_modal_close() {
            $("#show_image").modal("hide");
        }

        var tblDetails;
        var date_from = "";
        var date_to = "";

        $(document).ready(function () {
            tblDetails = $("#tblDetails");

            // Logika Pengaturan Tanggal (Default: Awal bulan s/d Hari ini)
            var today = new Date();
            var dd = String(today.getDate()).padStart(2, '0');
            var mm = String(today.getMonth() + 1).padStart(2, '0');
            var yyyy = today.getFullYear();

            var current_day = yyyy + '-' + mm + '-' + dd;
            var first_day_month = yyyy + '-' + mm + '-01';

            date_from = $('#date_from').val() || first_day_month;
            date_to = $('#date_to').val() || current_day;

            $('#date_from').val(date_from);
            $('#date_to').val(date_to);

            $("#modal_update").on('hidden.bs.modal', function () {
                updateURLWithReportId(null, null);
            });

            if (localStorage.getItem('openPointsFilterState0')) {
                if (typeof restoreFilterStates === "function") {
                    restoreFilterStates();
                } else {
                    table_apply();
                }
            } else {
                table_apply();
            }

            $('#container_due_date_update').datetimepicker({
                format: 'YYYY-MM-DD',
                useCurrent: false,
                allowInputToggle: true 
            });

            $('#modal_update').on('hidden.bs.modal', function () {
                $('#due_date').val('');
                $('#container_due_date_update').datetimepicker('clear');
            });
        });

        // Fungsi untuk mengambil data dari server via AJAX dan menginisialisasi DataTable
        function table_apply() {
            spinner_loading = $("#spinner_loading");
            spinner_loading.css("display", "block");
            var date_from = $('#date_from').val()
            var date_to = $('#date_to').val()
            var select_cell_name = $('#select_cell_name').val()
            var select_family = $('#select_family').val()

            $.ajax({
                type: "GET",
                url: "@Url.Action("ShowOpenPoints0")",
                data: {
                    date_from: date_from,
                    date_to: date_to,
                    cell_name: select_cell_name,
                    family: select_family
                },
                success: function (data) {
                    tblDetails.html(data);

                    var table = $("#table_details").DataTable({
                        "paging": true,
                        "ordering": true,
                        "order": [],
                        "info": true,
                        "scrollX": false,
                        "searching": true,
                        "lengthChange": true,
                        "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                        "pageLength": 25,
                        "fixedHeader": true,
                        "columnDefs": [
                        {
                            "targets": 0,
                            "type": "report-id-numeric"
                        }
                    ],
                        "initComplete": function (settings, json) {
                            // Fungsi ini menambahkan input teks filter di bawah setiap header kolom dan menangani logika pencarian kolom secara real-time
                            $("#table_details").wrap("<div style='overflow:auto; width:100%;position:relative;'></div>");  
                        
                            var filterRow = $('<tr class="filter-row"></tr>');
                            var headers = $(this.api().table().header()).find('th');

                            headers.each(function (index) {
                                var th = $(this);
                                var filterCell = $('<th></th>');

                                if (index < headers.length - 1) {
                                    var input = $('<input>', {
                                        type: 'text',
                                        class: 'form-control form-control-sm column-filter text-center',
                                        placeholder: 'Filter ' + th.text(),
                                        style: 'min-width: 90px;'
                                    });

                                    filterCell.append(input);
                                } else {
                                    filterCell.text(''); 
                                }

                                filterRow.append(filterCell);
                            });

                            $(this.api().table().header()).append(filterRow);

                            this.api().columns().every(function (index) {
                                var column = this;

                                if (index < headers.length - 1) {
                                    $('tr.filter-row th:eq(' + index + ') input').on('keyup change clear', function () {
                                        if (column.search() !== this.value) {
                                            column
                                                .search(this.value)
                                                .draw();
                                        }
                                    });
                                }
                            });

                            spinner_loading.css("display", "none");
                        }
                    });
                },
                complete: function () {
                    spinner_filter = $("#spinner_filter");  

                    // Logika untuk mengembalikan state filter dari LocalStorage jika ada
                    if (localStorage.getItem('openPointsFilterState0')) {
                        spinner_filter.css("display", "block");
                        const filterStateAgain = JSON.parse(localStorage.getItem('openPointsFilterState0'));
                        $('#table_details thead tr.filter-row th input').each(function (index) {
                            if (index < filterStateAgain.columnFilters.length && filterStateAgain.columnFilters[index]) {
                                $(this).val(filterStateAgain.columnFilters[index]);
                                $(this).trigger('keyup');
                            }
                        });
                    }
                    spinner_filter.css("display", "none");
                    autoOpenModalFromURL();
                },
                error: function (err) {
                    console.log(err);
                }
            });
        }

        // Fungsi untuk mengisi data ke dalam modal Update Action dan menampilkannya
        function btn_update(reportID, category, supplier, partNumber, criticality, requirement, picName, deptName, initialComment, fileImage) {

            $('#update_part_number_hidden').val(reportID);
            $('#category').val(category);
            $('#supplier').val(supplier);
            $('#part_number').val(partNumber);

            $('#requirement').val(requirement);
            $('#criticality').val(criticality);
            $('#initial_pic_name').val(picName);
            $('#initial_dept_name').val(deptName);
            $('#initial_comment').val(initialComment);

            var noImagePath = '@Url.Content("~/images/not_available.png")';
            var basePath = '@Url.Content("~/uploads/nok_images/")'; 
            var imagePath = basePath + fileImage;
            $(".initial_nok_pic").attr("src", imagePath);
            $(".initial_nok_pic").attr("onerror", "this.onerror=null;this.src='" + noImagePath + "';");

            $(".initial_nok_pic").off('click').on('click', function() {
                zoomImage(imagePath, "Defect Picture"); 
            });

            $('#pic_action').val('');
            $('#due_date').val('');
            $('#pic_af1').attr('src', '@Url.Content("~/assets/CameraNG.png")'); 
            $('#image_af_upload1').val(null); 

            $('.input-group.date').datetimepicker({
                format: 'YYYY-MM-DD',
                useCurrent: false
            });

            updateURLWithReportId(reportID, 'update');

            $('#due_date').val('');
            $("#modal_update").modal('show');
        }

        // Fungsi untuk menampilkan modal verify untuk menyelesaikan (close) open point
        function verify_open_points(checking_id, id1, id2, id3, partNumber, supplierName, category, due_Date, fileActionImage) {
            $('#checking_id_Verify').val(checking_id)
            $('#id1_Verify').val(id1)
            $('#id2_Verify').val(id2)
            $('#id3_Verify').val(id3)
            $('#category_Verify').val(category);     
            $('#part_number_Verify').val(partNumber);
            $('#supplier_Verify').val(supplierName);   
            $("#due_date_Verify").val(due_Date);

            // Logika menampilkan gambar perbaikan
            var noImagePath = '@Url.Content("~/images/not_available.png")';
            var actionBasePath = '@Url.Content("~/uploads/actions/")'; 

            if (fileActionImage && fileActionImage !== "") {
                var actionImageUrl = actionBasePath + fileActionImage;
                $("#action_image_preview").attr("src", actionImageUrl);

                $("#action_image_preview").off('click').on('click', function () {
                    zoomImage(actionImageUrl, "PIC Action Picture");
                });
            } else {
                $("#action_image_preview").attr("src", noImagePath);
                $("#action_image_preview").off('click');
            }

            $("#modal_verify").modal('show');
        }

        // Fungsi untuk mengirim data update (action dan image action)
        function update() {
            var reportID = $('#update_part_number_hidden').val(); 
            var picAction = $('#pic_action').val();
            var dueDate = $('#due_date').val();
            var imageFile = $('#image_af_upload1')[0].files[0];

            if (!picAction || !dueDate || !imageFile) {
                Swal.fire('Error', 'Please fill in the Action, Due Date, and Upload a Picture.', 'error');
                return;
            }

            var formData = new FormData();
            formData.append('reportID', reportID);
            formData.append('picAction', picAction);
            formData.append('dueDate', dueDate);
            if (imageFile) {
                formData.append('imageFile', imageFile);
            }

            Swal.fire({
                title: 'Save Changes?',
                text: "Make sure the data you entered is correct.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, Save!',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("UpdateAction", "SmartIQC")",
                        data: formData,
                        processData: false, 
                        contentType: false, 
                        success: function (response) {
                            if (response.success) {
                                Swal.fire('Success!', 'Data updated successfully.', 'success').then(() => {
                                    updateURLWithReportId(null, null);
                                    location.reload();
                                });
                            } else {
                                Swal.fire('Failed!', response.message, 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Error!', 'Unable to connect to server.', 'error');
                        }
                    });
                }
            });
        }

        // Fungsi untuk mengirim instruksi verify ke server untuk menutup status (closed) Open Point
        function verify() {
            var reportID = $('#checking_id_Verify').val();

            if (!reportID) {
                Swal.fire('Error', 'Report ID is missing.', 'error');
                return;
            }

            Swal.fire({
                title: 'Verify Open Point?',
                text: "Are you sure you want to verify this data?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#dc3545',
                confirmButtonText: 'Yes, Verify!',
                cancelButtonText: 'No',
                showLoaderOnConfirm: true, 
                preConfirm: function () {
                    return $.ajax({
                        type: "POST",
                        url: "@Url.Action("VerifyOpenPoint", "SmartIQC")",
                        data: { reportID: reportID },
                        dataType: "json"
                    }).done(function (response) {
                        return response; 
                    }).fail(function (xhr, status, error) {
                        Swal.showValidationMessage(`Request failed: ${error}`);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    if (result.value.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: 'Verified Successfully!'
                        }).then(() => {
                            location.reload(); 
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Verification Failed',
                            text: result.value.message || 'Please check if the action has been updated first.'
                        });
                    }
                }
            });
        }

        // Fungsi untuk menampilkan modal untuk change PIC
        function change_pic(reportID, currentPic) {
            $('#oldPIC').val(currentPic);
            $('#hidden_part_number_for_pic_change').val(reportID);

            $('#newPIC').val(null).trigger('change');
            $("#modal_pic_change").modal('show');
        }

        $(document).ready(function () {
            if ($('#newPIC').length) {
                $('#newPIC').select2({
                    placeholder: 'Select New PIC',
                    width: '100%',
                    dropdownParent: $('#modal_pic_change'),
                    ajax: {
                        url: '@Url.Action("GetPICs", "SmartIQC")',
                        dataType: 'json',
                        delay: 250,
                        data: function (params) {
                            return {
                                term: params.term 
                            };
                        },
                        processResults: function (data) {
                            return data; 
                        },
                        cache: true
                    }
                });
            }
        });

        // Fungsi untuk mengirim data perubahan PIC baru ke server
        function changePIC() {
            var reportID = $('#hidden_part_number_for_pic_change').val();
            var newPicSesaId = $('#newPIC').val();
            if (!newPicSesaId) {
                Swal.fire('Warning', 'Please select a new PIC first.', 'warning');
                return;
            }
            Swal.fire({
                title: 'Are you sure?',
                text: "PIC for Report ID " + reportID + " will change.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#dc3545',
                confirmButtonText: 'Yes, change PIC!',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        type: "POST",
                        url: '@Url.Action("UpdatePIC", "SmartIQC")',
                        data: {
                            reportID: reportID,
                            newPicSesaId: newPicSesaId
                        },
                        dataType: "json",
                        success: function (response) {
                            if (response.success) {
                                Swal.fire(
                                    'Success!',
                                    'PIC has been changed successfully.',
                                    'success'
                                ).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire(
                                    'Gagal!',
                                    response.message || 'An error occurred while updating the data.',
                                    'error'
                                );
                            }
                        },
                        error: function () {
                            Swal.fire(
                                'Error!',
                                'Unable to connect to server.',
                                'error'
                            );
                        }
                    });
                }
            });
        }

        // Fungsi untuk memperbarui string di URL browser agar bisa di share (agar langsung buka modal dari email)
        function updateURLWithReportId(reportID, modalType) {
            const url = new URL(window.location.origin + window.location.pathname);

            url.searchParams.delete('order_id');
            url.searchParams.delete('modal');

            if (reportID) {
                url.searchParams.set('order_id', reportID);
                url.searchParams.set('modal', modalType);
            } else {
                url.searchParams.delete('modal');
            }
            history.pushState({ reportID: reportID, modal: modalType }, '', url.pathname + url.search);
        }

        // Fungsi untuk membersihkan Report ID dari karakter ilegal atau potongan URL yang tidak perlu
        function cleanReportIdFromUrl(rawReportID) {
            if (!rawReportID) return null;

            let decodedID = rawReportID; 
            let parts = decodedID.split('-');

            if (parts.length > 3) {
                let cleanID = parts[0] + '-' + parts[1] + '-' + parts[2];
                console.warn('CleanReportIdFromUrl: The long ID chunk becomes:', cleanID);
                return cleanID;
            } 
    
            if (decodedID.includes('&')) {
                return decodedID.split('&')[0];
            }

            return decodedID;
        }

        // Fungsi untuk mengambil nilai parameter spesifik dari URL browser
        function getUrlParameter(name) {
            name = name.replace(/[\[]/, '\\[').replace(/[\]]/, '\\]');
            var regex = new RegExp('[\\?&]' + name + '=([^&#]*)');
            var results = regex.exec(location.search);
            return results === null ? '' : decodeURIComponent(results[1].replace(/\+/g, ' ')); 
        }

        // Fungsi untuk mendeteksi parameter URL saat halaman dimuat untuk membuka modal secara otomatis (fitur email)
        function autoOpenModalFromURL() {
            var rawReportIDFromUrl = getUrlParameter('order_id');
            var modalTypeFromUrl = getUrlParameter('modal');
            var cleanReportID = cleanReportIdFromUrl(rawReportIDFromUrl);

            if (cleanReportID && modalTypeFromUrl === 'update') {
                $("#spinner_loading").css("display", "block");

                $.ajax({
                    type: "GET",
                    url: "@Url.Action("GetOpenPointDetails", "SmartIQC")",
                    data: { reportID: cleanReportID },
                    dataType: "json",
                    success: function (response) {
                        $("#spinner_loading").css("display", "none");

                        if (response.success && response.data) {
                            var item = response.data;
                            btn_update(
                                item.report_ID, item.category, item.supplier_Name, 
                                item.part_Number, item.critical_Part_Status, item.requirement, 
                                item.piC_Name, item.dept_Name, item.comment, item.file_Image
                            );
                        } 
                        else if (response.isCompleted) {
                            Swal.fire({
                                title: 'Completed!',
                                text: response.message,
                                icon: 'success',
                                confirmButtonText: 'OK'
                            }).then(() => {
                                updateURLWithReportId(null, null);
                            });
                        }
                        else {
                            Swal.fire('Error', response.message, 'error');
                        }
                    },
                    error: function () {
                        $("#spinner_loading").css("display", "none");
                        Swal.fire('Error', 'Internal Server Error', 'error');
                    }
                });
            }
        }

        // Function to sortir report id berdasarkan asc/desc 
        jQuery.extend(jQuery.fn.dataTableExt.oSort, {
            "report-id-numeric-asc": function (a, b) {
                var x = parseInt(a.split('-')[0], 10);
                var y = parseInt(b.split('-')[0], 10);

                if (isNaN(x)) x = 0;
                if (isNaN(y)) y = 0;

                return ((x < y) ? -1 : ((x > y) ? 1 : 0));
            },

            "report-id-numeric-desc": function (a, b) {
                var x = parseInt(a.split('-')[0], 10);
                var y = parseInt(b.split('-')[0], 10);

                if (isNaN(x)) x = 0;
                if (isNaN(y)) y = 0;

                return ((x < y) ? 1 : ((x > y) ? -1 : 0));
            }
        });
    </script>
}
