@using Smart_IQC.Models
@using Microsoft.AspNetCore.Http

@model ViewModel

<style>
    .hero {
        min-height: 70px;
        position: relative;
        display: flex;
        align-items: center;
        color: #fff;
        margin-bottom: 0 !important;
        z-index: 1;
    }

    .hero .position-absolute {
        width: 100%;
    }

    .hero .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.65);
    }

    .hero .hero-body {
        position: relative;
        z-index: 2;
        width: 100%;
    }

    .hero .hero-title {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: 0.2px;
    }

    .inner {
        height: 70px;
        position: relative;
    }

    .main-content-row {
        margin-top: 0 !important;
        padding-top: 0 !important;
    }

    .hero {
        margin-bottom: 0 !important;
    }

    
    .dashboard-card {
        background: #ffffff;
        border-radius: 15px !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1) !important;
        border: none !important;
        margin-bottom: 30px;
        position: relative;
        z-index: 10;
    }

    .dashboard-card:hover {
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    }

    .dashboard-card .card-body {
        padding: 24px;
    }

    .mt-n4 {
        margin-top: -45px !important;
    }

    .dashboard-card .card-body {
        padding: 35px !important;
    }

    .px-md-5 {
        padding-left: 0.5rem !important;
        padding-right: 0.5rem !important;
    }

    .container-fluid {
        max-width: 98%;
        margin: 0 auto;
    }

    .dashboard-card .card-body {
        padding: 30px !important;
    }

    @@media (max-width: 768px) {
        .px-md-5 {
            padding-left: 0.75rem !important;
            padding-right: 0.75rem !important;
        }
    }

    .modal-dialog {
        max-width: 90% !important;
        padding: 0;
        margin: 1.75rem auto;
    }

    .modal {
        padding: 0 !important;
        overflow-y: auto !important;
    }

    
    .effect:hover, .effect:focus, .effect:active {
        box-shadow: 0 0 8px rgba(0, 0, 0, 0.6);
    }

    
    .filter-row {
        background-color: #f4f4f4;
    }

    .filter-row th {
        padding: 5px !important;
    }

    .filter-row .column-filter {
        width: 100%;
        min-width: 90px;
        font-size: 8pt;
        border: 1px solid #d2d6de;
    }

    
    #table_details thead tr.filter-row th input {
        display: block;
        width: 100%;
        height: calc(1.5em + .5rem + 2px);
        padding: .25rem .5rem;
        font-size: 8pt;
        line-height: 1.5;
        color: #495057;
        background-color: #fff;
        background-clip: padding-box;
        border: 1px solid #ced4da;
        border-radius: .25rem;
        transition: border-color .15s ease-in-out,box-shadow .15s ease-in-out;
    }

    .modal-content {
        overflow: hidden;
        border-radius: 12px !important;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        max-height: none;
    }

    body.modal-open {
        overflow: hidden !important;
        padding-right: 0px !important;
    }
</style>

<section id="hero" class="hero bg-dark position-relative" style="background: url('@Url.Content("~/images/background/background-iqc.jpg")') center center / cover no-repeat fixed;">
    <div class="inner d-flex justify-content-between align-items-center px-3 py-2 w-100">
        <div class="position-absolute top-50 start-50 translate-middle text-center">
            <h3 class="text-white mb-0">
                <i class="fa fa-exclamation-circle text-success"></i>
                <b>Open Points</b>
            </h3>
        </div>
    </div>
</section>

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12 mt-3">
                <div class="dashboard-card card-light">
                    <div class="card-body">
                        <div id="spinner_loading" style="display: none;">
                            <div class="d-flex justify-content-center align-items-center text-center">
                                <strong>Loading...</strong></br>
                                <div class="spinner-border spinner-border-sm ml-3" role="status" aria-hidden="true"></div>
                            </div>
                        </div>
                        <div id="spinner_filter" style="display: none;">
                            <div class="d-flex justify-content-center align-items-center text-center">
                                <strong>Loading Filter...</strong></br>
                                <div class="spinner-border spinner-border-sm ml-3" role="status" aria-hidden="true"></div>
                            </div>
                        </div>
                        <div class="col-12 mt-3 table-responsive" id="tblDetails" style="overflow-x: auto; white-space: nowrap; scrollbar-width: thin; scroll-behavior: smooth;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Modal Verify *@
<div id="modal_verify" class="modal fade" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa fa-info-circle mr-2"></i> Verify Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="title text-center"><h3 id="show_tester_name"><i class="fa fa-info-circle mr-2"></i> Verify</h3></div>
                <input hidden class="form form-control" id="id1_Verify" />
                <input hidden class="form form-control" id="id2_Verify" />
                <input hidden class="form form-control" id="id3_Verify" />
                <input hidden class="form form-control" id="shift_name_Verify" />

                <div class="row">
                    <div class="col-3 mx-auto">
                        <label style="font-size:10pt;">Report ID </label>
                        <input type="text" id="checking_id_Verify" class="form-control form-control-sm" disabled />
                    </div>
                    <div class="col-3 mx-auto">
                        <label style="font-size:10pt;">Category </label>
                        <input type="text" id="category_Verify" class="form-control form-control-sm" disabled />
                    </div>
                    <div class="col-3 mx-auto">
                        <label style="font-size:10pt;">Part Number </label>
                        <input type="text" id="part_number_Verify" class="form-control form-control-sm" disabled />
                    </div>
                    <div class="col-3 mx-auto">
                        <label style="font-size:10pt;"> Due date</label>
                        <div class="input-group" data-target-input="nearest">
                            <input type="text" id="due_date_Verify" class="form-control form-control-sm" data-target="#due_date" placeholder="Select Due Date" readonly />
                            <div class="input-group-append" data-target="#due_date">
                                <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row mt-4">
                    <div class="col-12 text-center">
                        <label style="font-size:10pt; font-weight:bold;">PIC Action Picture</label>
                        <br />
                        <img id="action_image_preview"
                             height="200"
                             width="200"
                             style="cursor: pointer; padding: 5px;"
                             src="@Url.Content("~/images/not_available.png")"
                             title="Click to zoom"
                             onerror="this.onerror=null;this.src='@Url.Content("~/images/not_available.png")';" />
                        <p class="text-muted" style="font-size: 10pt;">Click image to full view</p>
                    </div>
                </div>
                <div class="row mt-5" style="margin-top:10px" id="action_btn">
                    <div class="col-6 mx-auto">
                        <div class="form-group">
                            <button class="btn btn-info btn-block" id="btn_verify" onclick="verify()"><i class="fas fa-check"></i> Verify</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Modal Update Action *@
<div id="modal_update" class="modal fade" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa fa-info-circle mr-2"></i> Data Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="title text-center"><h3 id="show_tester_name"><i class="fa fa-info-circle mr-2"></i> Update</h3></div>
                <input type="hidden" id="update_part_number_hidden" />
                <input hidden class="form form-control" id="id1" />
                <input hidden class="form form-control" id="id2" />
                <input hidden class="form form-control" id="id3" />
                <input hidden class="form form-control" id="shift_name" />
                <div class="row">
                    <div class="col-6">
                        <label style="font-size:10pt;">Defect Description</label>
                        <textarea id="requirement" class="form-control form-control-sm" rows="2" disabled></textarea>
                    </div>
                    <div class="col-6">
                        <label style="font-size:10pt;">Comment</label>
                        <textarea id="initial_comment" class="form-control form-control-sm" rows="2" disabled></textarea>
                    </div>
                    <div class="col-4 mt-2">
                        <label style="font-size:10pt;">PIC</label>
                        <input type="text" id="initial_pic_name" class="form-control form-control-sm" disabled />
                    </div>
                    <div class="col-4 mt-2">
                        <label style="font-size:10pt;">Critical</label>
                        <input type="text" id="criticality" class="form-control form-control-sm" disabled />
                    </div>
                    <div class="col-4 mt-2">
                        <label style="font-size:10pt;">Department</label>
                        <input type="text" id="initial_dept_name" class="form-control form-control-sm" disabled />
                    </div>
                    <div class="col-12 text-center mt-3">
                        <label style="font-size:10pt;">Defect Picture</label><br />
                        <img class="initial_nok_pic"
                             height="100"
                             width="100"
                             style="cursor: pointer"
                             src="@Url.Content("~/images/not_available.png")"
                             onerror="this.onerror=null;this.src='@Url.Content("~/images/not_available.png")';" />
                        <p class="text-muted" style="font-size: 10pt;">Click image to full view</p>
                    </div>
                </div>
                <div class="row mt-5">
                    <div class="col-3 mx-auto">
                        <label style="font-size:10pt;">Category </label>
                        <input type="text" id="category" class="form-control form-control-sm" disabled />
                    </div>
                    <div class="col-3 mx-auto">
                        <label style="font-size:10pt;">Part Number </label>
                        <input type="text" id="part_number" class="form-control form-control-sm" disabled />
                    </div>
                    <div class="col-3 mx-auto">
                        <label style="font-size:10pt;">Supplier </label>
                        <input type="text" id="supplier" class="form-control form-control-sm" disabled />
                    </div>
                    <div class="col-3 mx-auto">
                        <label style="font-size:10pt;"> Due date <sup class="text-red text-bold">(*)</sup></label>
                        <div class="input-group date" id="container_due_date_update" data-target-input="nearest">
                            <input type="text" id="due_date" class="form-control form-control-sm datetimepicker-input"
                                   data-target="#container_due_date_update" placeholder="Select Due Date" />
                            <div class="input-group-append" data-target="#container_due_date_update" data-toggle="datetimepicker">
                                <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-8 mt-3">
                        <label style="font-size:10pt;">Action <sup class="text-red text-bold">(*)</sup></label>
                        <textarea class="form-control form-control-sm" type="text" id="pic_action" rows="2" style="height:70px;"></textarea>
                    </div>
                    <div class="col-4">
                        <div class="row justify-content-md-center mt-3">
                            <div class="col-4 text-center">
                                <label>Upload Picture <sup class="text-red text-bold">(*)</sup></label>
                                <br />
                                <img id="pic_af1" src="~/assets/CameraNG.png" alt="Picture Before" style="max-width:80%;height:auto" />
                                <input onchange="readimgaf1(this);" type="file" id="image_af_upload1" name="image_af_upload1" accept="image/png, image/jpeg" hidden />
                                <br />
                                <button name="btn_af_upload1" class="btn btn-success btn-sm mt-2 mb-3"><i class="fa fa-upload"></i> Upload</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row mt-5" style="margin-top:10px" id="action_btn">
                    <div class="col-6 mx-auto">
                        <div class="form-group">
                            <button class="btn btn-success btn-block btn-sm" onclick="update()"><i class="fas fa-check"></i> Update</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

