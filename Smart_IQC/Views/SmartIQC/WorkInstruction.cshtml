@model List<P1F_IQC.Models.WorkInstructionModel>
@{
    ViewData["Title"] = "Work Instruction";
}

<style>
    /* Konfigurasi ukuran font */
    #table_wi_list tbody td {
        font-size: 11pt !important; 
        color: #333 !important;
        vertical-align: middle !important;
    }

    #table_wi_list thead th {
        font-size: 11pt !important;
        font-weight: 600 !important;
    }

    .dataTables_length select {
        width: 60px !important;
        display: inline-block !important;
        padding: 2px !important;
        height: 30px !important;
        padding-left: 5px !important;
    }

    #table_wi_list thead th.no-sort::before,
    #table_wi_list thead th.no-sort::after {
        display: none !important;
        content: "" !important;
    }

    .wi-card {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 15px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
        transition: all 0.3s ease-in-out;
        cursor: pointer;
    }

    .wi-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.1);
    }

    .wi-book {
        width: 150px;
        height: auto;
        margin-bottom: 15px;
        transition: transform 0.3s ease-in-out;
    }

    .wi-card:hover .wi-book {
        transform: scale(1.1);
    }

    .wi-title {
        font-weight: 600;
        font-size: 1.1rem;
        color: #343a40;
        margin-bottom: 0;
    }

    #wiListModal .modal-body {
        min-height: 200px;
    }

    .hero {
        min-height: 70px;
        position: relative;
        display: flex;
        align-items: center;
        color: #fff;
        margin-bottom: 0 !important;
        z-index: 1;
    }

    .hero .position-absolute {
        width: 100%;
    }

    .hero .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.65);
    }

    .hero .hero-body {
        position: relative;
        z-index: 2;
        width: 100%;
    }

    .hero .hero-title {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: 0.2px;
    }

    .inner {
        height: 70px;
        position: relative;
    }

    .main-content-row {
        margin-top: 0 !important;
        padding-top: 0 !important;
    }

    .hero {
        margin-bottom: 0 !important;
    }

    /* Penyelarasan Kartu Dashboard */
    .dashboard-card {
        background: #ffffff;
        border-radius: 15px !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1) !important;
        border: none !important;
        margin-bottom: 30px;
        position: relative;
        z-index: 10;
    }

    .dashboard-card:hover {
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    }

    .dashboard-card .card-body {
        padding: 24px;
    }

    .mt-n4 {
        margin-top: -45px !important;
    }

    .dashboard-card .card-body {
        padding: 35px !important;
    }

    .px-md-5 {
        padding-left: 0.5rem !important;
        padding-right: 0.5rem !important;
    }

    .container-fluid {
        max-width: 98%;
        margin: 0 auto;
    }

    .dashboard-card .card-body {
        padding: 30px !important;
    }

    @@media (max-width: 768px) {
        .px-md-5 {
            padding-left: 0.75rem !important;
            padding-right: 0.75rem !important;
        }
    }
</style>

<section id="hero" class="hero bg-dark position-relative" style="background: url('@Url.Content("~/images/background/background-iqc.jpg")') center center / cover no-repeat fixed;">
    <div class="inner d-flex justify-content-between align-items-center px-3 py-2 w-100">
        <div class="position-absolute top-50 start-50 translate-middle text-center">
            <h3 class="text-white mb-0">
                <i class="fa fa-file-alt text-success"></i>
                <b>Work Instruction Smart IQC</b>
            </h3>
        </div>
    </div>
</section>

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12 mt-2">
                <div class="dashboard-card card-light">
                    <div class="card-body">
                        <div class="row d-flex justify-content-center align-items-center" style="min-height: 300px;">
                            <div class="col-md-3">
                                <input type="file" id="wi-file-input" name="workInstructionFile" style="display: none;" />
                                <div class="wi-card" id="wi-card-trigger" title="Click to view Work Instructions">
                                    <img src="~/images/logo/manual-book.png" alt="Manual Book" class="wi-book" />
                                    <h5 class="wi-title">View WI Smart IQC</h5>
                                </div>
                                @if (User.HasClaim("p1f_iqc_level", "admin"))
                                {
                                    <button class="btn btn-info btn-block wi-button mt-4" id="upload-button-trigger"><i class="fas fa-upload mr-2"></i>Upload New WI</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="wiListModal" tabindex="-1" role="dialog" aria-labelledby="wiListModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="wiListModalLabel"><i class="fas fa-list-ul mr-2"></i>List Work Instruction</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table professional-table w-100" id="table_wi_list">
                            <thead>
                                <tr class="bg-info text-white text-center">
                                    <th>WI Name</th>
                                    <th>WI Type</th>
                                    <th>Uploaded By</th>
                                    <th>Record Date</th>
                                    <th class="no-sort">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var wiFile in Model)
                                {
                                    var fileUrl = Url.Content($"~/uploads/wi/{wiFile.file_name}");

                                    <tr>
                                        <td class="align-middle">
                                            <i class="fas fa-file-pdf text-danger mr-2"></i> @wiFile.file_name
                                        </td>
                                        <td class="align-middle text-center">
                                            <span class="badge" style="background-color: #fff3e0; color: #e65100; border: 1px solid #ffe0b2; padding: 5px 10px;">
                                                @wiFile.wi_type
                                            </span>
                                        </td>
                                        <td class="align-middle text-center">@wiFile.upload_by</td>
                                        <td class="align-middle text-center">
                                            @wiFile.record_date.ToString("dd MMM yyyy, hh:mm tt")
                                        </td>
                                        <td class="align-middle text-center">
                                            <button class="btn btn-sm btn-info open-preview"
                                                    data-url="@fileUrl"
                                                    data-filename="@wiFile.file_name"
                                                    title="Preview PDF">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="documentPreviewModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
        <div class="modal-content" style="height: 90vh;">
            <div class="modal-header">
                <h5 class="modal-title" id="documentPreviewTitle">Preview</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-0">
                <iframe id="documentViewer" src="" style="width: 100%; height: 100%; border: none;"></iframe>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var tableWI;

            // Inisialisasi DataTables
            $('#wiListModal').on('show.bs.modal', function () {
                setTimeout(function() {
                    if (!$.fn.DataTable.isDataTable('#table_wi_list')) {
                        tableWI = $('#table_wi_list').DataTable({
                            "paging": true,
                            "lengthChange": true,
                            "searching": true,
                            "ordering": true,
                            "info": true,
                            "autoWidth": false,
                            "responsive": true,
                            "pageLength": 10, // Default entries set 10
                            "lengthMenu": [[5, 10, 25, 50, -1], [5, 10, 25, 50, "All"]], 
                            "order": [[4, "desc"]],
                            "columnDefs": [{ "targets": "no-sort", "orderable": false }],
                            "language": {
                                "search": "Search:",
                                "lengthMenu": "Show _MENU_ entries",
                                "paginate": { "next": "Next", "previous": "Previous" }
                            }
                        });
                    } else {
                        tableWI.columns.adjust().draw();
                    }
                }, 100); 
            });

            $('#wi-card-trigger').on('click', function() {
                $('#wiListModal').modal('show');
            });

            $('#upload-button-trigger').on('click', function() {
                $('#wi-file-input').click();
            });

            $('#wi-file-input').on('change', function() {
                var file = this.files[0];
                if (file) {
                    var fileName = file.name;
                    var fileExtension = fileName.split('.').pop().toLowerCase();

                    if (fileExtension !== 'pdf') {
                        Swal.fire({
                            icon: 'error',
                            title: 'Invalid File Type',
                            text: 'Only PDF files are allowed for Work Instructions.'
                        });
                        $(this).val('');
                        return;
                    }

                    var formData = new FormData();
                    formData.append('workInstructionFile', file);

                    Swal.fire({
                        title: 'Uploading...',
                        text: 'Please wait while the file is being uploaded.',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading(); }
                    });

                    $.ajax({
                        url: '@Url.Action("UploadWorkInstruction", "SmartIQC")?type=IQC',
                        type: 'POST',
                        data: formData,
                        processData: false,
                        contentType: false,
                        success: function(response) {
                            if (response.success) {
                                Swal.fire({ icon: 'success', title: 'Success!', text: response.message }).then(() => { location.reload(); });
                            } else {
                                Swal.fire({ icon: 'error', title: 'Upload Failed', text: response.message });
                            }
                        }
                    });
                }
                $(this).val('');
            });

            // Preview PDF
            $(document).on('click', '.open-preview', function(e) {
                e.preventDefault();
                var fileUrl = $(this).data('url');
                var fileName = $(this).data('filename');
                $('#documentPreviewTitle').text(fileName);
                $('#documentViewer').attr('src', fileUrl);
                $('#wiListModal').modal('hide');
                $('#documentPreviewModal').modal('show');
            });

            $('#documentPreviewModal').on('hidden.bs.modal', function () {
                $('#documentViewer').attr('src', '');
                $('#wiListModal').modal('show');
            });
        });
    </script>
}